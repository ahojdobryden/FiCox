ggplot_outliers_plotting <- function(dataset,y_of_outlier, x_of_outlier, quantile=0.5) {
require(ggplot2)
require(quantreg)
plot_data <- rbind(dataset, c(y_of_outlier, x_of_outlier))  # dataset including the outlier observation
estim_nooutlier <- coef(lm(foodexp~income, data = dataset))
estim_nooutlier_qr <- coef(rq(foodexp~income, data = dataset, tau = quantile))
estim <- coef(lm(foodexp~income, data = plot_data)) # Gives the beta coefficients
estim_qr <- coef(rq(foodexp~income, data = plot_data, tau = quantile))
plot <- ggplot(aes(x=income, y=foodexp), data=plot_data)
plot <- plot + geom_point()
plot <- plot + geom_abline(intercept = estim_nooutlier[1], slope = estim_nooutlier[2], linetype="dashed") # dashed - OLS without outlier
plot <- plot + geom_abline(intercept = estim[1], slope = estim[2], colour="red",linetype="dashed") # red dashed - OLS with outlier
plot <- plot + geom_abline(intercept = estim_nooutlier_qr[1], slope = estim_nooutlier_qr[2], colour = "blue") # blue - quantile regression q=0.5 - median without outlier
plot <- plot + geom_abline(intercept = estim_qr[1], slope = estim_qr[2], colour = "purple") # purple - quantile regression  with outlier
plot <- plot + geom_point(aes(x=y_of_outlier, y=x_of_outlier), colour="red",) # added observation/outlier highlighted in red
print(plot)
}
# you can check how different outliers will affect estimation results
options(repr.plot.width=10, repr.plot.height=6)
ggplot_outliers_plotting(dataset=engel, 9000, 800, quantile=0.5)
options(repr.plot.width=10, repr.plot.height=7)

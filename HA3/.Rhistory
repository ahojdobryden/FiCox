# Time axis
t <- seq(0, , 300,by = 0.1)
K <- 100
# Form 1
a1 <- -3
b1 <- 0.3
F1 <- K / (1 + exp(-a1 - b1 * t))
# Form 2
c2 <- 0.3
d2 <- 10
F2 <- K / (1 + exp(-c2 * (t - d2)))
# Form 3
g3 <- 0.3
e3 <- exp(3)  # since a1 = -3
F3 <- K / (1 + e3 * exp(-g3 * t))
# Plot
plot(t, F1, type = "l", col = "blue", ylim = c(0, K), lwd = 2, ylab = "F(t)", main = "Comparison of Logistic Forms")
lines(t, F2, col = "red", lwd = 2, lty = 2)
lines(t, F3, col = "green", lwd = 2, lty = 3)
# Form 1
a1 <- 3
b1 <- 0.3
F1 <- K / (1 + exp(a1 - b1 * t))
# Form 2
c2 <- 0.3
d2 <- 10
F2 <- K / (1 + exp(-c2 * (t - d2)))
# Form 3
g3 <- 0.3
e3 <- exp(3)  # since a1 = -3
F3 <- K / (1 + e3 * exp(-g3 * t))
# Plot
plot(t, F1, type = "l", col = "blue", ylim = c(0, K), lwd = 2, ylab = "F(t)", main = "Comparison of Logistic Forms")
lines(t, F2, col = "red", lwd = 2, lty = 2)
lines(t, F3, col = "green", lwd = 2, lty = 3)
# Time axis
t <- seq(0, 30, by = 0.1)
K <- 100
# Form 1
a1 <- -3
b1 <- 0.3
F1 <- K / (1 + exp(-a1 - b1 * t))
inflect1 <- -a1 / b1  # Inflection point for Form 1
# Form 2
c2 <- 0.3
d2 <- 10
F2 <- K / (1 + exp(-c2 * (t - d2)))
inflect2 <- d2  # Inflection point for Form 2
# Form 3
g3 <- 0.3
e3 <- exp(3)  # since a1 = -3
F3 <- K / (1 + e3 * exp(-g3 * t))
inflect3 <- log(e3) / g3  # Inflection point for Form 3
# Plot
plot(t, F1, type = "l", col = "blue", ylim = c(0, K), lwd = 2, ylab = "F(t)", main = "Logistic Curves with Inflection Points")
lines(t, F2, col = "red", lwd = 2, lty = 2)
lines(t, F3, col = "green", lwd = 2, lty = 3)
# Add inflection point lines
abline(v = inflect1, col = "blue", lty = 1, lwd = 1.5)
abline(v = inflect2, col = "red", lty = 2, lwd = 1.5)
abline(v = inflect3, col = "green", lty = 3, lwd = 1.5)
# Add legend
legend("bottomright",
legend = c("Form 1", "Form 2", "Form 3"),
col = c("blue", "red", "green"),
lty = 1:3,
lwd = 2)
# Form 3
g3 <- 0.7
e3 <- exp(3)  # since a1 = -3
F3 <- K / (1 + e3 * exp(-g3 * t))
inflect3 <- log(e3) / g3  # Inflection point for Form 3
# Plot
plot(t, F1, type = "l", col = "blue", ylim = c(0, K), lwd = 2, ylab = "F(t)", main = "Logistic Curves with Inflection Points")
lines(t, F2, col = "red", lwd = 2, lty = 2)
lines(t, F3, col = "green", lwd = 2, lty = 3)
# Add inflection point lines
abline(v = inflect1, col = "blue", lty = 1, lwd = 1.5)
abline(v = inflect2, col = "red", lty = 2, lwd = 1.5)
abline(v = inflect3, col = "green", lty = 3, lwd = 1.5)
# Time range
t <- seq(0, 30, by = 0.1)
K <- 100
# Form 1: F(t) = K * exp(-exp(-b*(t - a)))
a1 <- 10
b1 <- 0.4
F1 <- K * exp(-exp(-b1 * (t - a1)))
inflect1 <- a1
# Form 2: F(t) = K * exp(-exp(c - d*t))
d2 <- 0.4
c2 <- d2 * a1
F2 <- K * exp(-exp(c2 - d2 * t))
inflect2 <- c2 / d2
# Form 3: F(t) = K * exp(-g * exp(-h * t))
h3 <- 0.4
g3 <- exp(-b1 * a1)  # same as exp(-4)
F3 <- K * exp(-g3 * exp(-h3 * t))
inflect3 <- log(g3) / -h3
# Plot
plot(t, F1, type = "l", col = "blue", ylim = c(0, K), lwd = 2, ylab = "F(t)", main = "Gompertz Curves with Inflection Points")
lines(t, F2, col = "red", lwd = 2, lty = 2)
lines(t, F3, col = "green", lwd = 2, lty = 3)
# Inflection point lines
abline(v = inflect1, col = "blue", lty = 1, lwd = 1.5)
abline(v = inflect2, col = "red", lty = 2, lwd = 1.5)
abline(v = inflect3, col = "green", lty = 3, lwd = 1.5)
legend("bottomright",
legend = c("Form 1", "Form 2", "Form 3"),
col = c("blue", "red", "green"),
lty = 1:3,
lwd = 2)
# Plot
plot(t, F1, type = "l", col = "blue", ylim = c(0, K), lwd = 2, ylab = "F(t)", main = "Gompertz Curves with Inflection Points")
lines(t, F2, col = "red", lwd = 2, lty = 2)
lines(t, F3, col = "green", lwd = 2, lty = 3)
# Inflection point lines
abline(v = inflect1, col = "blue", lty = 1, lwd = 1.5)
